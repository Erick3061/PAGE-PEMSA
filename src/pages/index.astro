---
import Layout from "../layouts/Layout.astro";
import banner from "../assets/banner.webp";
import social from "../assets/social.webp";
import experiencia from "../assets/check/experiencia.png";
import cobertura from "../assets/check/cobertura.png";
import confianza from "../assets/check/confianza.png";
import flexibilidad from "../assets/check/flexibilidad.png";
import calidad from "../assets/check/calidad.png";
import Button from "../components/ui/Button.astro";
import { siteConfig } from "../config/site";
import Features from "../components/widgets/Features.astro";
import Content2 from "../components/widgets/Content2.astro";
import ServiceList from "../components/widgets/ServiceList.astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Card from "../components/ui/Card.astro";
import Headline from "../components/ui/Headline.astro";
const metadata = {
    title: `${siteConfig.name} — The next step for your project`,
    description: siteConfig.description,
    ignoreTitleTemplate: true,
};

const Clients: { name: string }[] = [
    { name: "Acciona" },
    { name: "Encinos" },
    { name: "Dico" },
    { name: "Compartamos" },
    { name: "Telmex" },
    { name: "gandhi" },
];

const Brands: { name: string }[] = [
    { name: "Apple" },
    { name: "Google" },
    { name: "Disney" },
    { name: "Amazon" },
    { name: "Samsung" },
    { name: "Sony" },
];
---

<Layout metadata={metadata}>
    <div class="reveal relative h-screen w-full overflow-hidden">
        <!-- <video
            autoplay
            loop
            muted
            playsinline
            class="absolute top-0 left-0 h-full w-full object-cover"
        >
            <source src={video} type="video/mp4" />
            Tu navegador no soporta la etiqueta de video.
        </video> -->
        <Image
            class="absolute top-0 left-0 h-full w-full object-cover"
            src={banner}
            alt={"banner"}
        />

        <div class="absolute top-0 left-0 h-full w-full bg-black opacity-20">
        </div>

        <div
            class="relative z-10 flex h-full md:w-1/2 ml-auto bg-card/70 items-center justify-center"
        >
            <div class="flex gap-4 flex-col text-center p-4 md:p-8">
                <h1 class="text-4xl md:text-4xl font-bold mb-4">
                    EVOLUCIONA LA SEGURIDAD DE TU HOGAR Y NEGOCIO AL SIGUIENTE
                    NIVEL
                </h1>
                <p class="font-semibold text-lg md:text-2xl mb-6">
                    MÁS DE 40 AÑOS DE EXPERIENCIA EN EL MERCADO NOS RESPALDAN
                </p>
                <p class="font-semibold text-xl mb-6">
                    Servicio a nivel nacional
                </p>
                <Button type="submit" href="/contact" class="max-w-max mx-auto"
                    >CONTÁCTANOS</Button
                >
                <a class="max-w-max mt-20 ml-auto font-bold" href={"/legal"}
                    >Aviso de privacidad</a
                >
            </div>
        </div>
    </div>

    <ServiceList
        classes={{
            container: "mb-5",
            custom: "grid grid-cols-1 md:grid-cols-2 gap-8 mt-10",
        }}
        title={siteConfig.nameLarge}
        tagline="¿Quiénes Somos?"
        services={[
            {
                title: "COMPROMISO",
                description:
                    "Ponemos toda nuestra experiencia y compromiso al servicio de su tranquilidad, asegurando que cada sistema contratado supere sus expectativas.",
                icon: "lucide:handshake",
                action: {
                    text: "Leer mas ...",
                    href: "/about",
                },
            },
            {
                title: "Más directa y confiable",
                description:
                    "Garantizamos que cada sistema, equipo y material utilizado cumple con estrictos índices de calidad.",
                icon: "lucide:book-check",
                action: {
                    text: "Leer mas ...",
                    href: "/about",
                },
            },
        ]}
    />
    <Features
        classes={{
            container: "mb-5",
        }}
        tagline="¿Qué Ofrecemos?"
        title="INTEGRACIÓN DE SISTEMAS DE SEGURIDAD ELECTRÓNICA"
        columns={5}
        features={[
            {
                title: "Intrusión - asalto",
                icon: "lucide:shield-alert",
                iconClass: "bg-blue-500/10 text-blue-400",
            },
            {
                title: "Control de acceso",
                icon: "lucide:door-open",
                iconClass: "bg-purple-500/10 text-purple-400",
            },
            {
                title: "Incendio",
                icon: "lucide:flame",
                iconClass: "bg-purple-500/10 text-purple-400",
            },
            {
                title: "Videovigilancia",
                icon: "lucide:cctv",
                iconClass: "bg-pink-500/10 text-pink-400",
            },
            {
                title: "Cercas electrificadas",
                icon: "lucide:fence",
                iconClass: "bg-pink-500/10 text-pink-400",
            },
        ]}
    />
    <Content2 image={social} imageAlt="Development">
        <Fragment>
            <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
                PEMSA
            </h3>
            <p class="text-lg">Mantente al tanto de noticias y promociones</p>
            <p class="text-md text-muted-foreground">
                Síguenos y mantente al tanto de nuestras redes sociales.
            </p>

            <div class="flex mt-8 sm:justify-baseline gap-3">
                <a
                    href="#"
                    class="text-body hover:text-heading flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary"
                >
                    <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M13.135 6H15V3h-1.865a4.147 4.147 0 0 0-4.142 4.142V9H7v3h2v9.938h3V12h2.021l.592-3H12V6.591A.6.6 0 0 1 12.592 6h.543Z"
                            clip-rule="evenodd"></path></svg
                    >
                    <span class="sr-only">Facebook page</span>
                </a>
                <a
                    href="#"
                    class="text-body hover:text-heading ms-5 flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary"
                >
                    <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            d="M18.942 5.556a16.3 16.3 0 0 0-4.126-1.3 12.04 12.04 0 0 0-.529 1.1 15.175 15.175 0 0 0-4.573 0 11.586 11.586 0 0 0-.535-1.1 16.274 16.274 0 0 0-4.129 1.3 17.392 17.392 0 0 0-2.868 11.662 15.785 15.785 0 0 0 4.963 2.521c.41-.564.773-1.16 1.084-1.785a10.638 10.638 0 0 1-1.706-.83c.143-.106.283-.217.418-.331a11.664 11.664 0 0 0 10.118 0c.137.114.277.225.418.331-.544.328-1.116.606-1.71.832a12.58 12.58 0 0 0 1.084 1.785 16.46 16.46 0 0 0 5.064-2.595 17.286 17.286 0 0 0-2.973-11.59ZM8.678 14.813a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.918 1.918 0 0 1 1.8 2.047 1.929 1.929 0 0 1-1.8 2.045Zm6.644 0a1.94 1.94 0 0 1-1.8-2.045 1.93 1.93 0 0 1 1.8-2.047 1.919 1.919 0 0 1 1.8 2.047 1.93 1.93 0 0 1-1.8 2.045Z"
                        ></path></svg
                    >
                    <span class="sr-only">Discord community</span>
                </a>
                <a
                    href="#"
                    class="text-body hover:text-heading ms-5 flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary"
                >
                    <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            d="M13.795 10.533 20.68 2h-3.073l-5.255 6.517L7.69 2H1l7.806 10.91L1.47 22h3.074l5.705-7.07L15.31 22H22l-8.205-11.467Zm-2.38 2.95L9.97 11.464 4.36 3.627h2.31l4.528 6.317 1.443 2.02 6.018 8.409h-2.31l-4.934-6.89Z"
                        ></path></svg
                    >
                    <span class="sr-only">Twitter page</span>
                </a>
                <a
                    href="#"
                    class="text-body hover:text-heading ms-5 flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary"
                >
                    <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M12.006 2a9.847 9.847 0 0 0-6.484 2.44 10.32 10.32 0 0 0-3.393 6.17 10.48 10.48 0 0 0 1.317 6.955 10.045 10.045 0 0 0 5.4 4.418c.504.095.683-.223.683-.494 0-.245-.01-1.052-.014-1.908-2.78.62-3.366-1.21-3.366-1.21a2.711 2.711 0 0 0-1.11-1.5c-.907-.637.07-.621.07-.621.317.044.62.163.885.346.266.183.487.426.647.71.135.253.318.476.538.655a2.079 2.079 0 0 0 2.37.196c.045-.52.27-1.006.635-1.37-2.219-.259-4.554-1.138-4.554-5.07a4.022 4.022 0 0 1 1.031-2.75 3.77 3.77 0 0 1 .096-2.713s.839-.275 2.749 1.05a9.26 9.26 0 0 1 5.004 0c1.906-1.325 2.74-1.05 2.74-1.05.37.858.406 1.828.101 2.713a4.017 4.017 0 0 1 1.029 2.75c0 3.939-2.339 4.805-4.564 5.058a2.471 2.471 0 0 1 .679 1.897c0 1.372-.012 2.477-.012 2.814 0 .272.18.592.687.492a10.05 10.05 0 0 0 5.388-4.421 10.473 10.473 0 0 0 1.313-6.948 10.32 10.32 0 0 0-3.39-6.165A9.847 9.847 0 0 0 12.007 2Z"
                            clip-rule="evenodd"></path></svg
                    >
                    <span class="sr-only">GitHub account</span>
                </a>
                <a
                    href="#"
                    class="text-body hover:text-heading ms-5 flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary"
                >
                    <svg
                        class="w-5 h-5"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            fill-rule="evenodd"
                            d="M12 2a10 10 0 1 0 10 10A10.009 10.009 0 0 0 12 2Zm6.613 4.614a8.523 8.523 0 0 1 1.93 5.32 20.093 20.093 0 0 0-5.949-.274c-.059-.149-.122-.292-.184-.441a23.879 23.879 0 0 0-.566-1.239 11.41 11.41 0 0 0 4.769-3.366ZM10 3.707a8.82 8.82 0 0 1 2-.238 8.5 8.5 0 0 1 5.664 2.152 9.608 9.608 0 0 1-4.476 3.087A45.755 45.755 0 0 0 10 3.707Zm-6.358 6.555a8.57 8.57 0 0 1 4.73-5.981 53.99 53.99 0 0 1 3.168 4.941 32.078 32.078 0 0 1-7.9 1.04h.002Zm2.01 7.46a8.51 8.51 0 0 1-2.2-5.707v-.262a31.641 31.641 0 0 0 8.777-1.219c.243.477.477.964.692 1.449-.114.032-.227.067-.336.1a13.569 13.569 0 0 0-6.942 5.636l.009.003ZM12 20.556a8.508 8.508 0 0 1-5.243-1.8 11.717 11.717 0 0 1 6.7-5.332.509.509 0 0 1 .055-.02 35.65 35.65 0 0 1 1.819 6.476 8.476 8.476 0 0 1-3.331.676Zm4.772-1.462A37.232 37.232 0 0 0 15.113 13a12.513 12.513 0 0 1 5.321.364 8.56 8.56 0 0 1-3.66 5.73h-.002Z"
                            clip-rule="evenodd"></path></svg
                    >
                    <span class="sr-only">Dribbble account</span>
                </a>
            </div>
            <div class="flex mt-8 sm:justify-baseline gap-3">
                <Button>Contactanos</Button>
            </div>
            <!-- <div
                    class={`flex items-center justify-center w-10 h-10 rounded-full bg-primary/10 text-primary`}
                >
                    
                    <Icon name={"lucide:check"} class="w-5 h-5" />
                </div> -->
        </Fragment>
    </Content2>

    <Content2
        items={[
            {
                title: "Open Source",
                description:
                    "Developed under the MIT license, free for personal and commercial use.",
                icon: "lucide:github",
                iconClass: "bg-indigo-500/10 text-indigo-400",
            },
            {
                title: "Community Driven",
                description:
                    "Built with the feedback and contributions of the developer community.",
                icon: "lucide:users",
                iconClass: "bg-orange-500/10 text-orange-400",
            },
            {
                title: "Regular Updates",
                description:
                    "Continuously improved with the latest technologies and best practices.",
                icon: "lucide:refresh-cw",
                iconClass: "bg-teal-500/10 text-teal-400",
            },
        ]}
        imageAlt="Community and Open Source"
        isReversed={true}
    >
        <Fragment>
            <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
                Open Source & Community
            </h3>
            Join the revolution of modern web development. This project is open for
            everyone to use, learn from, and contribute to.
        </Fragment>
    </Content2>

    <div class={`mt-16 p-5 flex flex-col md:gap-16 bg-primary/5`}>
        <Headline
            title="¿Por qué elegirnos?"
            classes={{
                container: "max-w-3xl mx-auto text-center",
            }}
        />
        <div
            class="mx-auto max-w-7xl grid gap-4 md:grid-cols-2 lg:grid-cols-3 lg:grid-rows-3 w-full"
        >
            <Card
                class="p-5 lg:col-start-1 lg:row-start-1 md:col-start-1 md:row-start-1"
            >
                <h3 class="text-lg text-center font-medium leading-6">
                    EXPERIENCIA
                </h3>
                <p class="mt-2 text-muted-foreground">
                    Contamos con más 35 años en el mercado de la seguridad
                    electrónica, con personal certificado en las diferentes
                    marcas de equipo que ofrecemos
                </p>
                <Image
                    alt={"experience"}
                    src={experiencia}
                    width={70}
                    height={70}
                    class={"logos-primary mx-auto mt-4"}
                />
            </Card>
            <Card
                class="p-5 lg:col-start-3 lg:row-start-1 md:col-start-2 md:row-start-1"
            >
                <h3 class="text-lg text-center font-medium leading-6">
                    CONFIANZA
                </h3>
                <p class="mt-2 text-muted-foreground">
                    Todos los servicios son atendidos por personal propio de la
                    empresa
                </p>
                <Image
                    alt={"experience"}
                    src={confianza}
                    width={70}
                    height={70}
                    class={"logos-primary mx-auto mt-4"}
                />
            </Card>
            <Card
                class="p-5 lg:col-start-2 lg:row-start-2 md:col-start-1 md:row-start-2"
            >
                <h3 class="text-lg text-center font-medium leading-6">
                    COBERTURA
                </h3>
                <p class="mt-2 text-muted-foreground">
                    Servicio a nivel nacional, brindamos atención en donde nos
                    necesitan nuestros clientes
                </p>
                <Image
                    alt={"experience"}
                    src={cobertura}
                    width={70}
                    height={70}
                    class={"logos-primary mx-auto mt-4"}
                />
            </Card>
            <Card
                class="p-5 lg:col-start-1 lg:row-start-3 md:col-start-2 md:row-start-2"
            >
                <h3 class="text-lg text-center font-medium leading-6">
                    CALIDAD
                </h3>
                <p class="mt-2 text-muted-foreground">
                    Estamos comprometidos en brindar servicios de calidad para
                    satisfacer los requerimientos de nuestros clientes
                </p>
                <Image
                    alt={"experience"}
                    src={calidad}
                    width={70}
                    height={70}
                    class={"logos-primary mx-auto mt-4"}
                />
            </Card>
            <Card
                class="p-5 lg:col-start-3 lg:row-start-3 md:col-start-1 md:row-start-3"
            >
                <h3 class="text-lg text-center font-medium leading-6">
                    FLEXIBILIDAD
                </h3>
                <p class="mt-2 text-muted-foreground">
                    Trabajamos de la mano con nuestros clientes, ofreciendo
                    soluciones que se adaptan a sus necesidades
                </p>
                <Image
                    alt={"experience"}
                    src={flexibilidad}
                    width={70}
                    height={70}
                    class={"logos-primary mx-auto mt-4"}
                />
            </Card>
        </div>
    </div>
    <div class={`mt-16 p-5 mx-auto max-w-7xl flex flex-col md:gap-16`}>
        <Headline
            title="CLIENTES"
            subtitle="Algunos de nuestros clientes satisfechos"
            classes={{
                container: "max-w-3xl mx-auto text-center",
            }}
        />
        <div class="container mx-auto">
            <div
                class="relative flex overflow-x-hidden border-b border-t border-transparent py-10"
            >
                <div
                    class="flex animate-[marquee_30s_linear_infinite] whitespace-nowrap"
                >
                    <div class="flex items-center justify-around gap-16 px-8">
                        {
                            Clients.map((client, idx) => (
                                <span class="text-3xl font-bold text-gray-300">
                                    {client.name.toUpperCase()}
                                </span>
                            ))
                        }
                    </div>
                    <div class="flex items-center justify-around gap-16 px-8">
                        {
                            Clients.map((client, idx) => (
                                <span class="text-3xl font-bold text-gray-300">
                                    {client.name.toUpperCase()}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class={`p-5 mx-auto max-w-7xl flex flex-col md:gap-16`}>
        <Headline
            title="MARCAS"
            subtitle="Marcas que confían en nuestro trabajo"
            classes={{
                container: "max-w-3xl mx-auto text-center",
            }}
        />
        <div class="container mx-auto">
            <div
                class="relative flex overflow-x-hidden border-b border-t border-transparent py-10"
            >
                <div
                    class="flex animate-[marquee_30s_linear_infinite] whitespace-nowrap"
                >
                    <div class="flex items-center justify-around gap-16 px-8">
                        {
                            Brands.map((brand, idx) => (
                                <span class="text-3xl font-bold text-gray-300">
                                    {brand.name.toUpperCase()}
                                </span>
                            ))
                        }
                    </div>
                    <div class="flex items-center justify-around gap-16 px-8">
                        {
                            Brands.map((brand, idx) => (
                                <span class="text-3xl font-bold text-gray-300">
                                    {brand.name.toUpperCase()}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
