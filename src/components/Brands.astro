    // { name: "Hochiki", icon: hochiki },
    // { name: "Honeywell", icon: honeywell },
    // { name: "IEI", icon: iei },
    // { name: "ISS", icon: iss },
    // { name: "Jablotron", icon: jablotron },
    // { name: "Kocom", icon: kocom },
    // { name: "March", icon: march },
    // { name: "Milestone", icon: milestone },
    // { name: "Notifier", icon: notifier },
    // { name: "Optex", icon: optex },
    // { name: "Pacom", icon: pacom },
    // { name: "Power Series Neo", icon: neo },
    // { name: "Protect", icon: protect },
    // { name: "Quolsys", icon: quolsys },
    // { name: "Rosslare", icon: rosslare },
    // { name: "Scati", icon: scati },
    // { name: "Seco-laram", icon: sl },
    // { name: "Sfire", icon: sfire },
    // { name: "Siera", icon: siera },
    // { name: "Syscom", icon: syscom },
    // { name: "System Sensor", icon: ss },
    // { name: "Suprema", icon: suprema },
    // { name: "Tp-Link", icon: tpLink },
