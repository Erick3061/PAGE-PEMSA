---
import { Image } from "astro:assets";
import accesspro from "../assets/brands/accesspro.webp";
import aiphone from "../assets/brands/aiphone.webp";
import argusa from "../assets/brands/argusa.webp";
import avigilon from "../assets/brands/avigilon.webp";
import axis from "../assets/brands/axis.webp";
import bosch from "../assets/brands/bosch.webp";
import came from "../assets/brands/came.webp";
import cdvi from "../assets/brands/cdvi.webp";
import dahua from "../assets/brands/dahua.webp";
import datalogic from "../assets/brands/datalogic.webp";
import desico from "../assets/brands/desico.webp";
import dmp from "../assets/brands/dmp.webp";
import dorlet from "../assets/brands/dorlet.webp";
import dsc from "../assets/brands/dsc.webp";
import edwards from "../assets/brands/edwards.webp";
import ezviz from "../assets/brands/ezviz.webp";
import ff from "../assets/brands/ff.webp";
import flir from "../assets/brands/flir.webp";
import genetec from "../assets/brands/genetec.webp";
import geutebruck from "../assets/brands/geutebruck.webp";
import hanwha from "../assets/brands/hanwha.webp";
import hid from "../assets/brands/hid.webp";
import Headline from "./ui/Headline.astro";
import Card from "./ui/Card.astro";

const data: { name: string; icon?: ImageMetadata }[] = [
    { name: "AccessPRO", icon: accesspro },
    { name: "Aiphone", icon: aiphone },
    { name: "Argusa", icon: argusa },
    { name: "Avigilon+", icon: avigilon },
    { name: "Axis", icon: axis },
    { name: "Bosch", icon: bosch },
    { name: "Came", icon: came },
    { name: "CDVI", icon: cdvi },
    { name: "Dahua", icon: dahua },
    { name: "Datalogic", icon: datalogic },
    { name: "Desico", icon: desico },
    { name: "DMP", icon: dmp },
    { name: "Dorlet", icon: dorlet },
    { name: "DSC", icon: dsc },
    { name: "EDWARDS", icon: edwards },
    { name: "EZVIZ", icon: ezviz },
    { name: "FF", icon: ff },
    { name: "FLIR", icon: flir },
    { name: "Genetec", icon: genetec },
    { name: "Geutebruck", icon: geutebruck },
    { name: "Hanwha", icon: hanwha },
    { name: "HID", icon: hid },
