---

<div class={`reveal p-5 mx-auto max-w-7xl flex flex-col md:gap-16`}>
    <Headline
        title="MARCAS"
        subtitle="Marcas que confían en nuestro trabajo"
        classes={{
            container: "max-w-3xl mx-auto text-center",
        }}
    />
    <div class="container mx-auto">
        <div
            class="relative flex overflow-x-hidden border-b border-t border-transparent"
        >
            <div
                class="flex animate-[marquee_60s_linear_infinite] whitespace-nowrap"
            >
                <div class="flex items-center justify-around gap-16 px-8">
                    {
                        data.map((client, idx) => (
                            <div class="p-0 m-0 w-50 h-50 flex flex-col items-center justify-center">
                                {client.icon && (
                                    <Image
                                        alt={`${client.icon}`}
                                        src={client.icon}
                                        class={"img"}
                                    />
                                )}
                                {/* <span class="text-2xl font-bold text-gray-300">
                                    {client.name}
                                </span> */}
                            </div>
                        ))
                    }
                </div>
                <div class="flex items-center justify-around gap-16 px-8">
                    {
                        data.map((client, idx) => (
                            <div class="p-0 m-0 w-50 h-50 flex flex-col items-center justify-center">
                                {client.icon && (
                                    <Image
                                        alt={`${client.icon}`}
                                        src={client.icon}
                                        class={"img"}
                                    />
                                )}
                                {/* <span class="text-2xl font-bold text-gray-300">
                                    {client.name}
                                </span> */}
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</div>
